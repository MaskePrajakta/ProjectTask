pipeline {
    agent any

    tools {
        maven 'Maven-3'
        jdk 'JDK-17'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/MaskePrajakta/ProjectTask.git'
            }
        }

        stage('Build') {
            steps {
                dir('SwaggerProjectTask') {
                    bat 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('SwaggerProjectTask') {
                    bat 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('SwaggerProjectTask') {
                    bat 'mvn package -DskipTests'
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('SwaggerProjectTask') {
                    bat 'java -jar target\\*.jar'
                }
            }
        }
    }
}